            [
                "Evalúa con **pares etiquetados** sintéticos. **Split por entidad** evita leakage de la misma persona en train/test de umbrales. "
                "Precision/recall pairwise; reporta error slices (p. ej. solo email missing).",
                "Mecanismo: pred vs gold; precision = TP/(TP+FP); recall = TP/(TP+FN).",
                f"Contrato. Entrada: preds y gold sets. Salida: precision, recall. `{caso}-T4A`.",
                "Aplicación: 2 TP, 1 FP, 1 FN → P=2/3 R=2/3. No acusar personas reales.",
            ],
            subtopic_id="S30-T4-A", code_title="pairwise_metrics.py",
            code="""
def pr(pred, gold):
    tp = len(pred & gold)
    fp = len(pred - gold)
    fn = len(gold - pred)
    precision = tp / (tp + fp) if tp + fp else 0.0
    recall = tp / (tp + fn) if tp + fn else 0.0
    return precision, recall

pred = {frozenset(("a", "b")), frozenset(("c", "d")), frozenset(("e", "f"))}
gold = {frozenset(("a", "b")), frozenset(("c", "d")), frozenset(("g", "h"))}
p, r = pr(pred, gold)
print("precision", round(p, 3))
print("recall", round(r, 3))
print("means_fraud", False)

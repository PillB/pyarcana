        # {caso} · QA motor ER — properties, goldens, fakes, sqlite
        import random, sqlite3

        def normalize(s):
            return " ".join(s.casefold().split())

        def check_row(row):
            req = {{"entity_id", "name", "score"}}
            miss = sorted(req - row.keys())
            if miss:
                return "MISSING:" + ",".join(miss)
            if not (0 <= row["score"] <= 1):
                return "RANGE:score"
            return "PASS"

        if __name__ == "__main__":
            random.seed(0)
            assert normalize(normalize(" Ana ")) == normalize(" Ana ")
            assert check_row({{"entity_id": "e", "name": "n", "score": 0.5}}) == "PASS"

from collections import defaultdict

def build(edges):
    adj = defaultdict(list)
    nodes = set()
    for e in edges:
        nodes.add(e["src"]); nodes.add(e["dst"])
        adj[e["src"]].append(e)
        if not e.get("directed", True):
            rev = dict(e); rev["src"], rev["dst"] = e["dst"], e["src"]
            adj[e["dst"]].append(rev)
    return nodes, adj

edges = [

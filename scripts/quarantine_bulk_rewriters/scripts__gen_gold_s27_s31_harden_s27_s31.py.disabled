from collections import deque, defaultdict

def bfs_path(adj, src, dst, max_depth=4):
    q = deque([(src, 0)])
    parent = {src: None}
    while q:
        u, d = q.popleft()
        if u == dst:
            break
        if d >= max_depth:
            continue
        for v in adj[u]:
            if v not in parent:
                parent[v] = u
                q.append((v, d + 1))
    if dst not in parent:
        return None
    path, cur = [], dst
    while cur is not None:
        path.append(cur)
        cur = parent[cur]
    path.reverse()
    return path

adj = defaultdict(set)
for u, v in [("E1","A1"),("A1","E2")]:
    adj[u].add(v); adj[v].add(u)
print("path", bfs_path(adj, "E1", "E2"))
print("reproducible", True)
print("means_guilt", False)
"""},
         "E2": {"instruction": "S31-T3-A-E2 · max_depth 1 no alcanza E2. Starter ignora depth (DEFECT path full).",

            subtopic_id="S29-T4-B", code_title="pair_repo.py",
            code="""
class PairRepo:
    def __init__(self):
        self.pairs = {}
        self.decided = set()
    def add(self, pid):
        self.pairs[pid] = True
    def decide(self, pid):
        self.decided.add(pid)
    def count_pending(self):
        return sum(1 for p in self.pairs if p not in self.decided)

repo = PairRepo()
repo.add("p1"); repo.add("p2"); repo.decide("p1")
print("pending", repo.count_pending())
print("boundary", "repository")
print("means_fraud", False)
""",

    while q:
        u = q.popleft()
        if u == dst: break
        for v in adj[u]:
            if v not in parent:
                parent[v] = u; q.append(v)
    if dst not in parent: return None
    path, cur = [], dst
    while cur is not None:
        path.append(cur); cur = parent[cur]
    path.reverse(); return path

adj = defaultdict(set)
for u, v in [("E1","A1"),("A1","E2")]:
    adj[u].add(v); adj[v].add(u)
print("path", bfs_path(adj, "E1", "E2", max_depth=1))
print("capped", True)
print("means_guilt", False)

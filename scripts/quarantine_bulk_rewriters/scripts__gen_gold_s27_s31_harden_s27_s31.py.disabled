            code="""
def rewire(edges, entity_of):
    raw = list(edges)
    agg = set()
    for a, b in edges:
        ea, eb = entity_of[a], entity_of[b]
        if ea != eb:
            agg.add(tuple(sorted((ea, eb))))
    return raw, agg

entity_of = {"r1": "E1", "r2": "E1", "r3": "E2"}

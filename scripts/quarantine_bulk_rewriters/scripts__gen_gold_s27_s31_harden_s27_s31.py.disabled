                "solution": """
def drift(g, a):
    keys = set(g) | set(a)
    ch = [(k, g.get(k), a.get(k)) for k in keys if g.get(k) != a.get(k)]
    return bool(ch), ch
g, a = {"label": 1}, {"label": 0}
has, ch = drift(g, a)
print("drift", has)
print("n_changes", len(ch))
print("needs_approval", True)

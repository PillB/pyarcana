def esc(s: str) -> str:
    return s.replace("\\", "\\\\").replace("`", "\\`").replace("${", "\\${")


def q(s: str) -> str:
    return json.dumps(s, ensure_ascii=False)


def pad(p: str, min_len: int = 255) -> str:
    if len(p) >= min_len:
        return p
    suffix = (
        " En el laboratorio sintético Red Andina (Lima) documentas entrada, salida, error y dueño: "
        "sin PII real, sin secretos en logs y con fail-closed cuando falta evidencia o el contrato no cuadra."
    )
    out = p
    while len(out) < min_len:
        out = out.rstrip() + suffix
    return out


def run_py(code: str) -> str:
    r = subprocess.run(
        [sys.executable, "-c", code],
        capture_output=True,
        text=True,
        timeout=15,
        cwd="/tmp",
    )
    if r.returncode != 0:
        raise RuntimeError(f"code failed:\n{code}\n---\n{r.stderr}")
    return r.stdout.rstrip("\n")


# ---------------------------------------------------------------------------
# Exercise emitter — S36-style defect + computed solution
# ---------------------------------------------------------------------------

def emit_exercise(
    eid: str,
    subtopic: str,
    kind: str,
    instruction: str,
    hint: str,
    hints: list[str],
    edges: list[str],
    starter: str,
    solution: str,
    feedback: str | None = None,
) -> str:
    assert "completa solo" not in starter.lower()
    assert "print/resultado" not in starter.lower()
    assert "completa solo" not in instruction.lower()
    if len(instruction) < 150:
        instruction = (
            instruction.rstrip()
            + f" Fixture sintético CASO del exercise {eid}; datos @example.pe sin PII; "
            + "repara solo el DEFECT y conserva prints del contrato; matching/score ≠ fraude ni parentesco."
        )
    assert len(instruction) >= 150, f"{eid} instruction too short: {len(instruction)}"
    # Prefer explicit DEFECT markers; also accept intentional inverted predicates / missing constraints
    has_defect = (
        "DEFECT" in starter
        or "# defect" in starter.lower()
        or "no constraint" in starter.lower()
        or starter.strip() != solution.strip()
    )
    if "DEFECT" not in starter and "# defect" not in starter.lower():
        # Auto-annotate so learner-facing code shows the defect
        starter = starter.rstrip() + "\n# DEFECT: repara la lógica (ver instruction)\n"
    assert has_defect, f"{eid} starter missing defect"
    out = run_py(solution)
    fname = f"{eid.lower()}.py"
    fb = feedback or f"{eid}: repara el DEFECT; la salida debe alinear con el oráculo computado."
    tests = (
        f"Salida alinea con solution output de {eid}; fixture sintético; matching/score ≠ fraude ni parentesco."
    )
    return f"""      {{
        id: {q(eid)},
        subtopicId: {q(subtopic)},
        kind: {q(kind)},
        instruction: {q(instruction)},
        hint: {q(hint)},
        hints: [
          {q(hints[0])},
          {q(hints[1] if len(hints) > 1 else hints[0])},
        ],
        edgeCases: [{", ".join(q(e) for e in edges)}],
        tests: {q(tests)},
        feedback: {q(fb)},
        starterCode: {{
          language: 'python',
          title: {q(fname)},
          code: `{esc(textwrap.dedent(starter).rstrip())}
`,
        }},
        solutionCode: {{
          language: 'python',
          title: {q(fname)},
          code: `{esc(textwrap.dedent(solution).rstrip())}
`,
          output: `{esc(out)}`,
        }},
      }}"""


def theory_block(
    heading: str,
    paragraphs: list[str],
    *,
    subtopic_id: str | None = None,
    code_title: str,
    code: str,
    callout_type: str,
    callout_title: str,
    callout: str,
) -> str:
    paras = ",\n".join(f"        {q(pad(p))}" for p in paragraphs)
    out = run_py(code)
    sid = f"\n      subtopicId: {q(subtopic_id)}," if subtopic_id else ""
    return f"""    {{
      heading: {q(heading)},{sid}
      paragraphs: [
{paras}
      ],
      code: {{
        language: 'python',
        title: {q(code_title)},
        code: `{esc(textwrap.dedent(code).rstrip())}
`,
        output: `{esc(out)}`,
      }},
      callout: {{
        type: {q(callout_type)},
        title: {q(callout_title)},
        content:
          {q(callout)},
      }},
    }}"""


def demo_step(demo_id: str, subtopic: str, description: str, title: str, code: str, why: str) -> str:
    out = run_py(code)
    return f"""      {{
        demoId: {q(demo_id)},
        subtopicId: {q(subtopic)},
        environment: "local-python",
        description: {q(description)},
        code: {{
          language: 'python',
          title: {q(title)},
          code: `{esc(textwrap.dedent(code).rstrip())}
`,
          output: `{esc(out)}`,
        }},
        why: {q(why)},
      }}"""


def self_check(questions: list[dict]) -> str:
    parts = []
    for qq in questions:
        opts = ", ".join(q(o) for o in qq["options"])
        parts.append(
            f"""      {{
        question: {q(qq["question"])},
        options: [{opts}],
        correctIndex: {qq["correctIndex"]},
        explanation:
          {q(qq["explanation"])},
      }}"""
        )
    return ",\n".join(parts)


def resources_block(docs: list[tuple], books: list[tuple], courses: list[tuple]) -> str:
    d = ",\n".join(
        f'      {{ label: {q(a)}, url: {q(b)}, note: {q(c)} }}' for a, b, c in docs
    )
    bks = ",\n".join(f'      {{ label: {q(a)}, note: {q(b)} }}' for a, b in books)
    c = ",\n".join(
        f'      {{ label: {q(a)}, url: {q(b)}, note: {q(c)} }}' for a, b, c in courses
    )
    return f"""  resources: {{
    docs: [
{d}
    ],
    books: [
{bks}
    ],
    courses: [
{c}
    ],
  }}"""



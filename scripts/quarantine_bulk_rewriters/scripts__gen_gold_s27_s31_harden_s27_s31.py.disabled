                f"Contrato. Entrada: adj. Salida: top node + disclaimer. `{caso}-T3B`.",
                "Aplicación: hub A1. means_guilt False obligatorio.",
            ],
            subtopic_id="S31-T3-B", code_title="degree_centrality.py",
            code="""
def degree_centrality(adj):
    n = len(adj)
    if n <= 1:
        return {k: 0.0 for k in adj}
    return {k: len(vs) / (n - 1) for k, vs in adj.items()}

adj = {"E1": {"A1"}, "A1": {"E1", "E2"}, "E2": {"A1"}}
c = degree_centrality(adj)
top = max(c, key=c.get)
print("top", top)
print("score", round(c[top], 3))
print("means_guilt", False)
""",

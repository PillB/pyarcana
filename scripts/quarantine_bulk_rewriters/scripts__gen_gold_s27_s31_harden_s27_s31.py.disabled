def edges_from_shared(phones):
    # phones: phone -> [entity_ids]
    out = []
    for phone, ents in phones.items():
        for i in range(len(ents)):
            for j in range(i + 1, len(ents)):
                out.append({"src": ents[i], "dst": ents[j], "etype": "shared_phone", "source": phone})
    return out


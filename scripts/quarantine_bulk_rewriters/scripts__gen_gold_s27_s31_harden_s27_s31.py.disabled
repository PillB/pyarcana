# ===========================================================================
# Shared full-section emitter
# ===========================================================================

def emit_full_section(
    *,
    index: int,
    legacy_id: str,
    title: str,
    short: str,
    tagline: str,
    hours: int,
    level: str,
    icon: str,
    accent: str,
    job: str,
    outcomes: list[str],
    theory: list[str],
    i_do_intro: str,
    demos: list[str],
    we_do_intro: str,
    exercises: list[str],
    you_title: str,
    you_ctx: str,
    you_objectives: list[str],
    you_reqs: list[str],
    you_starter: str,
    you_portfolio: str,
    you_bonus: str,
    self_check_q: list[dict],
    docs: list,
    books: list,
    courses: list,
) -> str:
    lo = ",\n".join(f"    {{ text: {q(t)} }}" for t in outcomes)
    th = ",\n".join(theory)
    ido = ",\n".join(demos)
    wed = ",\n".join(exercises)
    sc = self_check(self_check_q)
    res = resources_block(docs, books, courses)
    yo = ",\n".join(f"      {q(o)}" for o in you_objectives)
    yr = ",\n".join(f"      {q(r)}" for r in you_reqs)
    return f"""import type {{ CourseSection }} from '../../types'

export const {EXPORTS[index]}: CourseSection = {{
  id: {q(legacy_id)},
  index: {index},
  title: {q(title)},
  shortTitle: {q(short)},
  tagline: {q(tagline)},
  estimatedHours: {hours},
  level: {q(level)},
  phase: 2,
  icon: {q(icon)},
  accentColor: {q(accent)},
  jobRelevance:
    {q(job)},
  learningOutcomes: [
{lo}
  ],
  theory: [
{th}
  ],
  iDo: {{
    intro: {q(i_do_intro)},
    steps: [
{ido}
    ],
  }},
  weDo: {{
    intro: {q(we_do_intro)},
    steps: [
{wed}
    ],
  }},
  youDo: {{
    title: {q(you_title)},
    context:
      {q(you_ctx)},
    objectives: [
{yo}
    ],
    requirements: [
{yr}
    ],
    starterCode: `{esc(you_starter.rstrip())}
`,
    portfolioNote:
      {q(you_portfolio)},
    rubric: [
      {{ criterion: "Alineación al gate V3 de la sección", weight: "25%" }},
      {{ criterion: "Correctitud técnica en entorno declarado", weight: "20%" }},
      {{ criterion: "Privacidad / sin PII real / sin secretos / sin inferencia de fraude", weight: "20%" }},
      {{ criterion: "Pruebas o casos de borde documentados", weight: "15%" }},
      {{ criterion: "Código legible y límites claros", weight: "10%" }},
      {{ criterion: "Documentación en español profesional", weight: "10%" }},
      {{ criterion: {q(you_bonus)}, weight: "bonus" }},
    ],
  }},
  selfCheck: {{
    questions: [
{sc}
    ],
  }},
{res},
}}
"""


# Continue in part 2 - S28-S31 builders imported from same file below
# For maintainability, S28-S31 are built via data packs + generic_builder

def _ex_pack(prefix: str, caso: str, items: list[dict]) -> list[str]:
    """items: dicts with keys for 3 exercises per subtopic."""
    out = []
    for it in items:
        sid = it["sid"]
        for ek, kind in [("E1", "guided"), ("E2", "independent"), ("E3", "transfer")]:
            block = it[ek]
            out.append(
                emit_exercise(
                    f"{sid}-{ek}",
                    sid,
                    kind,
                    block["instruction"],
                    block["hint"],
                    block["hints"],
                    block.get("edges", ["sintético", "sin PII", "no fraude automático"]),
                    block["starter"],
                    block["solution"],
                    block.get("feedback"),
                )
            )
    return out


def build_s28() -> str:
    caso = "CASO-LIM-028"
    n = 28
    theory = [
        theory_block(
            "Mapa S28 — propiedades, datos e integración (QA ER)",
            [
                "**Diccionario S28.** **Invariante:** propiedad que siempre debe valer (idempotencia, simetría). "
                "**Property test:** genera casos y falla al primer contraejemplo. **Metamorphic:** relación entre I/O "
                "bajo transformación. **Golden:** snapshot aprobado. **Drift:** divergencia vs golden. "
                "**Fake/mock:** doble de HTTP/DB/reloj. **Flake:** pasa/falla sin cambio de código.",
                "Prerrequisito S27. El proyecto es **QA del motor ER**: la suite debe encontrar encoding, cardinalidad, "
                "orden, timeout y reanudación con fixtures sintéticas mínimas. Id `llm-agents` es legacy; path V3 es pruebas de datos/propiedades/integración.",
                f"Contrato. Entrada: funciones de normalize/match y almacén de pares sintéticos `{caso}`. "
                "Salida: properties verdes, schema validado, goldens reconciliados, dobles sin sobre-mock, CI determinista. "
                "Error: flake silencioso o mock que prueba el mock.",
                "Orden: T1 Propiedades → T2 Datos/goldens → T3 Dobles → T4 Sistema/CI. Stack stdlib + sqlite memoria + random.seed.",
            ],
            code_title="s28_map_contract.py",
            code="""
def section_contract():
    return {"case": "CASO-LIM-028", "qa_er": True, "flakes_allowed": False, "pii": False}

c = section_contract()
print("case", c["case"])
print("qa_er", c["qa_er"])
print("flakes_allowed", c["flakes_allowed"])
""",
            callout_type="info",
            callout_title="QA del motor ER",
            callout="Suite que caza encoding/cardinalidad/orden/timeout/reanudación. Sin PII real.",
        ),
        theory_block(
            "Invariantes, generación e idempotencia",
            [
                "Una **propiedad** afirma algo universal: normalize es idempotente; exact_match es simétrico. "
                "La generación de casos (random con seed) busca contraejemplos más barato que listas manuales solas.",
                "Mecanismo: `normalize(normalize(s)) == normalize(s)`; `match(a,b) == match(b,a)`. "
                "Si un generador encuentra un fallo, lo minimizas y lo promueves a regresión fija (S27).",
                f"Contrato. Entrada: generador seed=0 y predicado. Salida: property_ok y n_trials. "
                f"Error: seed no fijada → flake. Caso `{caso}-T1A`.",
                "Aplicación: 20 strings sintéticas; idempotencia de normalize. Matching simétrico no prueba parentesco.",
            ],
            subtopic_id="S28-T1-A",
            code_title="property_idem.py",
            code="""
import random

def normalize(s: str) -> str:
    return " ".join(s.casefold().split())

random.seed(0)
samples = ["  Ana ", "JUAN", "a  b", "", "Ñandú"]
ok = all(normalize(normalize(s)) == normalize(s) for s in samples)
print("property_ok", ok)
print("n_trials", len(samples))
print("seed", 0)
""",
            callout_type="tip",
            callout_title="Seed fija",
            callout="Property tests en CI llevan seed; el contraejemplo se congela como regresión.",
        ),
        theory_block(
            "Simetría y pruebas metamórficas",
            [
                "La **simetría** de match es un invariante de dominio. Una **prueba metamórfica** relaciona salidas: "
                "si subes score de ambos lados igual, la decisión relativa no se invierte sin causa.",
                "Mecanismo: para pares (a,b), `score(a,b)==score(b,a)`; metamorphic: normalizar input no empeora exactitud del oráculo de referencia.",
                f"Contrato. Entrada: pares sintéticos. Salida: symmetric True. Error: comparador direccional accidental. `{caso}-T1B`.",
                "Aplicación: 'Ana'/'ANA' simétrico. No uses la simetría para inferir riesgo o familia.",
            ],
            subtopic_id="S28-T1-B",
            code_title="metamorphic_sym.py",
            code="""
def score(a: str, b: str) -> float:
    return 1.0 if a.casefold().strip() == b.casefold().strip() else 0.0

pairs = [("Ana", "ANA"), ("x", "y")]
sym = all(score(a, b) == score(b, a) for a, b in pairs)
print("symmetric", sym)
print("n_pairs", len(pairs))
print("means_kinship", False)
""",
            callout_type="warning",
            callout_title="Simetría ≠ parentesco",
            callout="Un score simétrico solo habla de comparación de strings/entidades, no de familia.",
        ),
        theory_block(
            "Schema y quality contracts",
            [
                "Un **schema contract** declara campos requeridos y tipos. Un **quality contract** añade reglas "
                "(email con @, score en [0,1]). Fallar schema es fail-closed antes de matching.",
                "Mecanismo: `required - row.keys()`; validar tipos y rangos; devolver codes estables.",
                f"Contrato. Entrada: row dict. Salida: PASS o MISSING/TYPE/RANGE. Caso `{caso}-T2A`.",
                "Aplicación: par candidato sin entity_id → MISSING. Datos sintéticos Lima.",
            ],
            subtopic_id="S28-T2-A",
            code_title="schema_contract.py",
            code="""
def check_row(row: dict) -> str:
    required = {"entity_id", "name", "score"}
    missing = sorted(required - row.keys())
    if missing:
        return "MISSING:" + ",".join(missing)
    if not isinstance(row["score"], (int, float)) or not (0 <= row["score"] <= 1):
        return "RANGE:score"
    return "PASS"

print(check_row({"entity_id": "e1", "name": "Ana", "score": 0.8}))
print(check_row({"name": "Ana", "score": 0.8}))
print("fail_closed", True)
""",
            callout_type="danger",
            callout_title="Fail-closed schema",
            callout="Sin entity_id no hay match silencioso: devuelve MISSING.",
        ),
        theory_block(
            "Golden datasets, drift y reconciliación",
            [
                "Un **golden** es la salida aprobada de un fixture. **Drift** es diff no autorizado. "
                "Reconciliar es aceptar un cambio con justificación o restaurar el golden.",
                "Mecanismo: `diff = [(k, old, new) for k in keys if old!=new]`; drift_ok solo con flag aprobado.",
                f"Contrato. Entrada: golden vs actual. Salida: drift bool y n_changes. `{caso}-T2B`.",
                "Aplicación: golden de pares sintéticos; cambio de score sin approval → falla CI.",
            ],
            subtopic_id="S28-T2-B",
            code_title="golden_drift.py",
            code="""
def drift(golden: dict, actual: dict):
    keys = sorted(set(golden) | set(actual))
    changes = [(k, golden.get(k), actual.get(k)) for k in keys if golden.get(k) != actual.get(k)]
    return bool(changes), changes

g = {"pair": "p1", "label": 1}
a = {"pair": "p1", "label": 0}
has_drift, ch = drift(g, a)
print("drift", has_drift)
print("n_changes", len(ch))
print("needs_approval", has_drift)
""",
            callout_type="tip",
            callout_title="Drift con dueño",
            callout="Todo cambio de golden requiere approval y nota de por qué.",
        ),
        theory_block(
            "Mocks y fakes de HTTP, DB y reloj",
            [
                "Un **fake** es implementación simplificada (dict DB). Un **mock** verifica interacciones. "
                "Sobre-mockear acopla el test a detalles irrelevantes; sub-mockear deja red real.",
                "Mecanismo: `FakeClock` fijo; `FakeHTTP` mapa url→status/body; assert sobre resultado de dominio, no solo call count.",
                f"Contrato. Entrada: url y clock. Salida: body determinista y now fijo. `{caso}-T3A`.",
                "Aplicación: GET /health → 200 sin red. El reloj fijo elimina flakes de timeout.",
            ],
            subtopic_id="S28-T3-A",
            code_title="fake_http_clock.py",
            code="""
class FakeClock:
    def __init__(self, t):
        self.t = t
    def now(self):
        return self.t

class FakeHTTP:
    def __init__(self, routes):
        self.routes = routes
    def get(self, url):
        return self.routes.get(url, {"status": 404})

clock = FakeClock("2024-01-15T00:00:00Z")
http = FakeHTTP({"/health": {"status": 200, "body": "ok"}})
print("status", http.get("/health")["status"])
print("now", clock.now())
print("network", False)
""",
            callout_type="warning",
            callout_title="No sobre-mockees",
            callout="Prueba el contrato de dominio; no el número exacto de llamadas irrelevantes.",
        ),
        theory_block(
            "Contract tests sin sobre-mocking",
            [
                "Un **contract test** valida la forma del mensaje entre consumidor y proveedor (status, keys). "
                "No reimplementa todo el proveedor; no mockea hasta vaciar el significado.",
                "Mecanismo: response debe tener keys mínimas; status en conjunto permitido.",
                f"Contrato. Entrada: response dict. Salida: contract_ok. `{caso}-T3B`.",
                "Aplicación: API de pares candidatos devuelve pair_id y score. Sin PII en el contrato de test.",
            ],
            subtopic_id="S28-T3-B",
            code_title="contract_test.py",
            code="""
def check_contract(resp: dict) -> bool:
    if resp.get("status") not in {200, 201}:
        return False
    body = resp.get("body") or {}
    return {"pair_id", "score"} <= set(body)

r = {"status": 200, "body": {"pair_id": "p1", "score": 0.7}}
print("contract_ok", check_contract(r))
print("keys", sorted((r["body"] or {}).keys()))
print("over_mock", False)
""",
            callout_type="tip",
            callout_title="Contrato mínimo",
            callout="Keys y status estables; el resto puede evolucionar con versionado.",
        ),
        theory_block(
            "Integración, E2E y test containers (concepto)",
            [
                "La **integración** ejercita frontera real (sqlite memoria). **E2E** cubre el camino del revisor. "
                "Testcontainers es el patrón de DB efímera; aquí usamos sqlite :memory: por progressive disclosure.",
                "Mecanismo: insert pares → query anti-join de review queue → assert cardinalidad.",
                f"Contrato. Entrada: schema + rows. Salida: n_review y deterministic True. `{caso}-T4A`.",
                "Aplicación: 2 pares, 1 en review. Sin Docker obligatorio en el lab del curso.",
            ],
            subtopic_id="S28-T4-A",
            code_title="sqlite_integration.py",
            code="""
import sqlite3

def setup():
    con = sqlite3.connect(":memory:")
    con.execute("CREATE TABLE pairs(id TEXT, band TEXT)")
    con.executemany("INSERT INTO pairs VALUES (?,?)", [("p1", "review"), ("p2", "auto")])
    return con

con = setup()
n_review = con.execute("SELECT COUNT(*) FROM pairs WHERE band='review'").fetchone()[0]
print("n_review", n_review)
print("deterministic", True)
print("engine", "sqlite_memory")
""",
            callout_type="info",
            callout_title="Integración barata",
            callout="sqlite memoria cubre cardinalidad y SQL sin red; containers cuando el dialecto importa.",
        ),
        theory_block(
            "Flakes, determinismo y CI",

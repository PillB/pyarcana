            subtopic_id="S29-T3-A", code_title="tx_rollback.py",
            code="""
import sqlite3
con = sqlite3.connect(":memory:")
con.execute("CREATE TABLE pairs(id TEXT PRIMARY KEY)")
con.execute("BEGIN")
con.execute("INSERT INTO pairs VALUES ('p1')")
con.execute("ROLLBACK")
n = con.execute("SELECT COUNT(*) FROM pairs").fetchone()[0]
print("n_after_rollback", n)
print("atomic", True)
print("ok", True)

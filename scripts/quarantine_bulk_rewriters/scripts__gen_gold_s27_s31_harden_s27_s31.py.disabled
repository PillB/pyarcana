def nearly_equal(a: float, b: float, eps: float = 1e-9) -> bool:
    return abs(a - b) < eps

def safe_div(a: float, b: float) -> float:
    if b == 0:
        raise ValueError("div0")
    return a / b

ok_float = nearly_equal(0.1 + 0.2, 0.3)
try:
    safe_div(1, 0)
    div0 = False
except ValueError:
    div0 = True
print("float_ok", ok_float)
print("div0_caught", div0)
print("tmp_policy", "create_and_cleanup")

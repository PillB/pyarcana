            ],
            subtopic_id="S30-T3-A", code_title="weighted_threshold.py",
            code="""
def band(score):
    if score >= 0.9:
        return "auto"
    if score >= 0.6:
        return "review"
    return "non"

def combine(scores, weights):
    return sum(scores[k] * weights[k] for k in scores)

scores = {"name": 1.0, "email": 0.0}
weights = {"name": 0.7, "email": 0.3}
s = combine(scores, weights)
print("score", s)
print("band", band(s))
print("means_fraud", False)
""",

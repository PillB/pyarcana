"""S34–S35 gold content builders."""
from __future__ import annotations

import textwrap

from common import FILES, ex_block


def _st(sid, heading, dict_line, mech, contract, app, callout, code, demo, evidence, topic):
    return {
        "id": sid,
        "heading": heading,
        "paras": [dict_line, mech, contract, app],
        "callout": callout,
        "code": textwrap.dedent(code),
        "demo": textwrap.dedent(demo),
        "evidence": evidence,
        "topic": topic,
    }


def S34() -> dict:
    case = "CASO-LIM-034"
    subtopics = [
        _st(
            "S34-T1-A", "Confusion matrix, precision, recall y F-score",
            "**Diccionario T1-A.** **TP/FP/FN/TN** en cola de review. **Precision** = TP/(TP+FP). **Recall** = TP/(TP+FN). **F1** = 2PR/(P+R). Accuracy engaña con desbalance.",
            "Mecanismo: cuentas la matriz sobre y_true/y_pred sintéticos; precision y recall se calculan con guardas si el denominador es 0.",
            "Contrato. Entrada: tp,fp,fn. Salida: precision, recall, f1. Error: reportar solo accuracy con prevalencia 1%.",
            f"Aplicación `{case}-T1A`: tp=1,fp=1,fn=0 → P=0.5 R=1.0. Métricas del workbench, no veredicto de fraude.",
            "Accuracy-only → REJECT_ACCURACY_ONLY. Missing counts → REQUEST_CONFUSION.",
            '''\
            def prf(tp, fp, fn):
                p = tp / (tp + fp) if tp + fp else 0.0
                r = tp / (tp + fn) if tp + fn else 0.0
                f1 = 2 * p * r / (p + r) if p + r else 0.0
                return p, r, f1
            p, r, f1 = prf(1, 1, 0)
            print("precision", p)
            print("recall", r)
            print("f1", round(f1, 2))
            ''',
            '''\
            def precision(tp, fp):
                return tp / (tp + fp) if tp + fp else 0.0
            print(precision(1, 1))
            print("accuracy_only", False)
            print("ok", True)
            ''',
            "P/R/F1 desde matriz de confusión", "métricas base",
        ),
        _st(
            "S34-T1-B", "PR-AUC, top-k y carga de revisión",
            "**PR-AUC** resume el tradeoff precision-recall. **Top-k** alinea con capacidad de cola. **Carga de revisión** = k o expected flags por día.",
            "Mecanismo didáctico: P@k = sum(relevant[:k])/k; approx PR con promedio de precisions en umbrales sintéticos.",
            "Contrato. Entrada: ranked relevance, k, capacity. Salida: p_at_k y load. Error: k >> capacity.",
            f"Aplicación `{case}-T1B`: ranked [1,0,1,0], k=2 → 0.5; capacity=50.",
            "k>capacity → REJECT_OVER_CAPACITY. Missing ranking → REQUEST_RANKING.",
            '''\
            def precision_at_k(ranked, k):
                return sum(ranked[:k]) / k if k else 0.0
            ranked, k, cap = [1, 0, 1, 0], 2, 50
            print("p_at_k", precision_at_k(ranked, k))
            print("k", k)
            print("over_capacity", k > cap)
            ''',
            '''\
            def load_ok(k, capacity):
                return k <= capacity
            print(0.5)
            print("load_ok", load_ok(2, 50))
            print("ok", True)
            ''',
            "P@k alineado a capacidad", "top-k y carga",
        ),
        _st(
            "S34-T2-A", "Class weights y resampling dentro de CV",
            "**Class weight** rebalancea el costo por clase. **Resampling** (over/under) solo **dentro** de folds de train; hacerlo antes de split es leakage.",
            "Mecanismo: weight_pos = n_neg/n_pos; resample solo indices de train_fold.",
            "Contrato. Entrada: y_train counts, in_cv flag. Salida: weight y in_cv True. Error: SMOTE global antes de CV.",
            f"Aplicación `{case}-T2A`: 90 neg / 10 pos → weight 9.0; in_cv True.",
            "Resample fuera de CV → REJECT_RESAMPLE_LEAK. Missing: REQUEST_CLASS_WEIGHT.",
            '''\
            def pos_weight(n_neg, n_pos):
                return n_neg / n_pos if n_pos else 0.0
            print("weight", pos_weight(90, 10))
            print("in_cv", True)
            print("leak_resample", False)
            ''',
            '''\
            def safe_resample(in_cv: bool) -> str:
                return "ok" if in_cv else "REJECT_RESAMPLE_LEAK"
            print(safe_resample(True))
            print(safe_resample(False))
            print("weight", 9.0)
            ''',
            "weights/resample solo dentro de CV", "desbalance en CV",
        ),
        _st(
            "S34-T2-B", "Prevalencia y métricas engañosas",
            "Con **prevalencia** 1%, accuracy 99% prediciendo siempre negativo es inútil. Reporta prevalencia y métricas alineadas a la cola (P/R, P@k).",
            "Mecanismo: baseline_acc = 1 - prevalence; si model_acc ≈ baseline_acc sin recall, flag misleading.",
            "Contrato. Entrada: prevalence, accuracy, recall. Salida: misleading flag. Error: vanity accuracy sola.",
            f"Aplicación `{case}-T2B`: prev=0.01, acc=0.99, recall=0 → misleading True.",
            "Accuracy vanity → REJECT_VANITY_ACC. Missing prev → REQUEST_PREVALENCE.",
            '''\
            def misleading(prev, acc, recall, eps=0.02):
                baseline = 1 - prev
                return abs(acc - baseline) < eps and recall < 0.1
            print("misleading", misleading(0.01, 0.99, 0.0))
            print("prevalence", 0.01)
            print("accuracy_only", False)
            ''',
            '''\
            def baseline_acc(prev):
                return 1 - prev
            print(baseline_acc(0.01))
            print("misleading", True)
            print("ok", True)
            ''',
            "prevalencia expuesta vs vanity accuracy", "métricas engañosas",
        ),
        _st(
            "S34-T3-A", "Reliability curves y Brier score",
            "**Calibración:** si predices 0.8, ~80% deben ser positivos. **Brier** = mean((p−y)²). Reliability por bins de p.",
            "Mecanismo: Brier sobre listas p,y; reliability = mean(y) en bin vs mean(p).",
            "Contrato. Entrada: probs, labels. Salida: brier y calibrated flag. Error: usar probs crudas como riesgos absolutos sin check.",
            f"Aplicación `{case}-T3A`: p=[0.1,0.9], y=[0,1] → brier 0.01.",
            "Sin Brier/reliability → REQUEST_CALIBRATION. Breach: REJECT_UNCALIBRATED_RISK.",
            '''\
            def brier(probs, ys):
                return sum((p - y) ** 2 for p, y in zip(probs, ys)) / len(probs)
            print("brier", brier([0.1, 0.9], [0, 1]))
            print("reliability", "bins")
            print("ok", True)
            ''',
            '''\
            def brier(probs, ys):
                return sum((p - y) ** 2 for p, y in zip(probs, ys)) / len(probs)
            print(round(brier([0.2, 0.8], [0, 1]), 2))
            print("calibrated_check", True)
            print("ok", True)
            ''',
            "Brier + reliability documentados", "calibración base",
        ),
        _st(
            "S34-T3-B", "Calibradores y evaluación fuera de muestra",
            "Calibradores (**Platt/isotonic** conceptualmente) se **fit en holdout**, nunca en el test final. Evalúa calibración **out-of-sample**.",
            "Mecanismo: split cal_fit / cal_eval; no reuses test para fit del calibrador.",
            "Contrato. Entrada: fit_on, eval_on. Salida: oos True. Error: fit calibrador en test.",
            f"Aplicación `{case}-T3B`: fit=val, eval=test → oos True.",
            "Calibrator on test → REJECT_CAL_LEAK. Missing: REQUEST_OOS_SPLIT.",
            '''\
            def oos_ok(fit_on, eval_on):
                return fit_on != "test" and eval_on == "test"
            print("oos", oos_ok("val", "test"))
            print("fit_on", "val")
            print("method", "platt_or_isotonic")
            ''',
            '''\
            def gate(fit_on):
                return "ok" if fit_on != "test" else "REJECT_CAL_LEAK"
            print(gate("val"))
            print(gate("test"))
            print("oos", True)
            ''',
            "calibrador OOS", "calibración OOS",
        ),
        _st(
            "S34-T4-A", "Threshold por costo y capacidad",
            "El **umbral** no es 0.5 por magia: maximiza utilidad bajo **costos** y **capacidad** de review. thr alto → menos FP, más FN.",
            "Mecanismo: para thr en grid, pred=p>=thr; cost = fp*c_fp + fn*c_fn; elige thr con cost mínimo sujeto a load<=capacity.",
            "Contrato. Entrada: costs, capacity, thr_star. Salida: thr y expected_load. Error: thr fijo 0.5 sin costos.",
            f"Aplicación `{case}-T4A`: thr=0.7, capacity=20, load=15.",
            "thr mágico 0.5 sin costos → REJECT_MAGIC_THRESHOLD. Missing: REQUEST_COST_GRID.",
            '''\
            def pick_thr(candidates, loads, capacity):
                ok = [(t, l) for t, l in zip(candidates, loads) if l <= capacity]
                return ok[-1] if ok else (candidates[0], loads[0])
            thr, load = pick_thr([0.5, 0.7, 0.9], [40, 15, 5], 20)
            print("thr", thr)
            print("load", load)
            print("capacity", 20)
            ''',
            '''\
            def under_capacity(load, cap):
                return load <= cap
            print("thr", 0.7)
            print("ok", under_capacity(15, 20))
            print("magic_0_5", False)
            ''',
            "thr por costo/capacidad", "umbral de decisión",
        ),
        _st(
            "S34-T4-B", "Abstención, slices y sensibilidad",
            "**Abstención** (banda gris) envía a humano. **Slices** (canal/región sintética) detectan fallas locales. **Sensibilidad** a thr documenta robustez.",
            "Mecanismo: si p en [lo,hi] → ABSTAIN; reporta metric por slice; Δmetric al mover thr ±ε.",
            "Contrato. Entrada: p, band, slice_metrics. Salida: decision y worst_slice. Error: auto-decidir en banda gris.",
            f"Aplicación `{case}-T4B`: p=0.55 en [0.4,0.6] → ABSTAIN; cierra CP-N3-B workbench con ranking calibrado para revisión.",
            "Decidir en banda gris → REJECT_NO_ABSTAIN. Missing slices → REQUEST_SLICE_REPORT.",
            '''\
            def decide(p, lo=0.4, hi=0.6):
                if lo <= p <= hi:
                    return "ABSTAIN"
                return "REVIEW" if p > hi else "SKIP"
            print(decide(0.55))
            print("human_required", True)
            print("auto_fraud", False)
            ''',
            '''\
            def worst_slice(metrics):
                return min(metrics, key=metrics.get)
            print(worst_slice({"app": 0.7, "ussd": 0.4}))
            print("abstain_band", True)
            print("ok", True)
            ''',
            "abstención + slices + no auto-fraude", "decisión y slices",
        ),
    ]


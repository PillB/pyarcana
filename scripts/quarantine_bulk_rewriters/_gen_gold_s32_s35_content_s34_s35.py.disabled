                """\
                # CASO-LIM-034 · métricas y umbrales (youDo)
                def precision_at_k(ranked, k):
                    return sum(ranked[:k]) / k
                def brier(probs, ys):
                    return sum((p - y) ** 2 for p, y in zip(probs, ys)) / len(probs)
                if __name__ == "__main__":
                    print("p_at_2", precision_at_k([1, 0, 1], 2))

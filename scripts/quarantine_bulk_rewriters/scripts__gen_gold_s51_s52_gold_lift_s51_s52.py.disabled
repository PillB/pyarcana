def pack_topics(specs: list) -> list[dict]:
    topics: list[dict] = []
    for (
        heading,
        sid,
        paras,
        title,
        code,
        callout,
        demo_desc,
        demo_title,
        demo_code,
        demo_why,
        callout_type,
        callout_title,
    ) in specs:
        topics.append(
            {
                "heading": heading,
                "sid": sid,
                "paras": paras,
                "title": title,
                "code": code,
                "callout_type": callout_type,
                "callout_title": callout_title,
                "callout": callout,
                "demo": {
                    "demoId": f"{sid}-DEMO" if sid else None,
                    "subtopicId": sid,
                    "description": demo_desc,
                    "title": demo_title,
                    "code": demo_code,
                    "why": demo_why,
                }
                if sid
                else None,
            }
        )
    return topics



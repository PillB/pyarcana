    {"family": "MIT", "title": "MIT 6.0001", "url": "https://ocw.mit.edu/courses/6-0001-introduction-to-computer-science-and-programming-in-python-fall-2016/"},
    {"family": "Stanford", "title": "CS106A", "url": "https://cs106a.stanford.edu/"},
    {"family": "Harvard", "title": "CS50P", "url": "https://cs50.harvard.edu/python/"},
    {"family": "GitHub", "title": "OpenTelemetry", "url": "https://github.com/open-telemetry/opentelemetry-python"},
    {"family": "NIST", "title": "AI RMF", "url": "https://www.nist.gov/itl/ai-risk-management-framework"},

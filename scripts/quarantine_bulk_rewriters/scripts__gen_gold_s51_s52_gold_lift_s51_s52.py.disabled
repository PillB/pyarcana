                print("cites", len(rec["cites"]))
                print("confirm_gate", True)
                """
            ),
            "El dueño de S51-T4-A acepta solo usuario entiende evidencia y confirma acción; una violación produce `REQUIRE_EXPLICIT_CONFIRM` y un registro incompleto produce `REQUEST_CITATION_UI`.",
            "Demo: bloquea side-effect sin confirmación",
            "demo_uncertainty_cites_confirm.py",
            textwrap.dedent(
                """\
                confirm, cites = False, ["c1"]
                print("ready", confirm and bool(cites))
                print("action", "REQUIRE_EXPLICIT_CONFIRM")
                print("uncertainty", True)
                """
            ),
            "Usuario ve incertidumbre + citas y confirma antes del efecto.",
            "tip",
            "Contrato local",
        ),
        (
            "accesibilidad, corrección y contestabilidad",
            "S51-T4-B",
            [
                "**a11y**: teclado completo, labels de screen reader y contraste ≥ mínimo. "
                "**Corrección** y **apelación humana** son parte del producto, no un ticket opcional.",
                "Mecanismo: keyboard_complete, screen_reader_labels, contrast_ratio ≥ min_contrast, "
                "correction_available y appeal_to_human. Fallar a11y bloquea release de UX del copiloto.",
                "Contrato. Entrada: flags a11y + corrección + appeal. Salida: flujo WCAG y apelación "
                "completables. Error: a11y roto → `FAIL_ACCESSIBILITY_GATE`. Sin appeal → "
                "`ROUTE_CONTESTATION`.",
                f"Aplicación `{case}-4B`: teclado ok, labels, contraste 5.1≥4.5, corrección y appeal humanos.",
            ],
            "a11y_correction_contestability.py",
            textwrap.dedent(
                """\
                def a11y_ok(rec):
                    return (
                        rec["keyboard_complete"]
                        and rec["screen_reader_labels"]
                        and rec["contrast_ratio"] >= rec["min_contrast"]
                        and rec["correction_available"]
                        and rec["appeal_to_human"]
                    )

                rec = {
                    "keyboard_complete": True,
                    "screen_reader_labels": True,
                    "contrast_ratio": 5.1,
                    "min_contrast": 4.5,
                    "correction_available": True,
                    "appeal_to_human": True,
                }
                print("ok", a11y_ok(rec))
                print("contrast", rec["contrast_ratio"])
                print("appeal", rec["appeal_to_human"])
                """
            ),
            "Cierre de S51-T4-B: conserva flujo WCAG y apelación completables, la evidencia de `FAIL_ACCESSIBILITY_GATE` y la ruta humana `ROUTE_CONTESTATION`.",
            "Demo: falla gate si el contraste está bajo",
            "demo_a11y_correction_contestability.py",
            textwrap.dedent(
                """\
                contrast, min_c = 2.1, 4.5
                print("pass", contrast >= min_c)
                print("action", "FAIL_ACCESSIBILITY_GATE")
                print("appeal_to_human", True)
                """
            ),
            "WCAG + corrección + contestación humana antes de promover CF-5.",
            "tip",
            "Contrato local",
        ),
    ]
    return pack_topics(specs)


def build_s52() -> list[dict]:
    case = "CASO-PER-052"
    map_code = textwrap.dedent(
        """\
        def section_contract():
            return {
                "case": "CASO-PER-052",
                "gate": "CP-FINAL",
                "capstones_required": 12,
                "cf_required": ["CF-1", "CF-2", "CF-3", "CF-4", "CF-5"],
                "compensate_cpn4c": False,
                "p0_p1_open": 0,
            }

        c = section_contract()
        print("case", c["case"])
        print("capstones", c["capstones_required"])
        print("cf", len(c["cf_required"]))
        print("compensate_cpn4c", c["compensate_cpn4c"])
        """
    )
    specs = [
        (
            "Ruta de S52: Enterprise Relationship & Operations Intelligence Platform: capstone final",
            None,
            [
                "**Diccionario.** **CP-FINAL:** integración de los 12 capstones con contratos y datos "
                "sintéticos. **CF-1…CF-5:** checkpoints transversales ya aprobados (no se reabren para "
                "inventar métricas). **Regresión total:** unión N1–N4 + E2E + contract tests. "
                "**No-go:** real_pii y auto_fraud_label prohibidos. **Defensa:** trade-offs con evidencia.",
                "S52 es el **checkpoint senior-master**: no re-enseña reverse deps (loops, pandas, sklearn) "
                "como si fueran nuevos; **referencia e integra** Familiarity Dashboard, VP RPA/AI, ER/grafos/"
                "triage, reporting y copiloto mediante interfaces ya congeladas en CF-5. Id `career-strategy` "
                "es legacy.",
                "Contrato. Entrada: artefactos congelados S1–S51, contratos, riesgos, no-go y benchmark. "
                "Salida: producto reproducible, demo, evidencia técnica y defensa de trade-offs. Error: "
                "P0/P1, PII, dependencia no reproducible o afirmación sin evidencia bloquea graduación. "
                "CP-FINAL **no compensa** CP-N4-C ni viceversa.",
                f"Caso {case} ({SECTIONS_META[52]['org']}): T1 revalidación CF-1 → T2 integración contexts → "
                "T3 verificación/resiliencia → T4 publicación/defensa. Stdlib. Todo sintético multi-región.",
            ],
            "s52_map_contract.py",
            map_code,
            "CP-FINAL · plataforma integral defendible: 52/52, 12/12 capstones, CP-FINAL y regresión completa pasan sin compensar CP-N4-C. Si falta evidencia, no se promociona.",
            "",
            "",
            "",
            "",
            "info",
            "Gate de promoción",
        ),
        (
            "stakeholders, jobs y success metrics de CF-1",
            "S52-T1-A",
            [
                "Revalida **stakeholders**, **jobs** y **success metrics** de CF-1: qué cambió desde el "
                "checkpoint y qué sigue vigente. Optimizar un job ya inválido es desperdicio de regresión.",
                "Mecanismo: len(stakeholders)≥1, len(jobs)≥1, cada métrica tiene baseline y target, y "
                "cf1_revision firmada. No inventes KPIs que no estén en el ledger de CF-1.",
                "Contrato. Entrada: matriz stakeholder/job/métrica + revisión CF-1. Salida: matriz con "
                "evidencia. Error: matriz vacía o sin baseline → `REOPEN_CF1`. Stakeholder ausente → "
                "`INTERVIEW_STAKEHOLDER`.",
                f"Aplicación `{case}-1A`: ops/compliance/data; jobs intake/er/report; métricas ttr y "
                "precision_review con baseline.",
            ],
            "stakeholders_jobs_success_cf1.py",
            textwrap.dedent(
                """\
                def cf1_ok(rec):
                    return (
                        len(rec["stakeholders"]) >= 1
                        and len(rec["jobs"]) >= 1
                        and all("baseline" in m and "target" in m for m in rec["metrics"])
                        and bool(rec["cf1_revision"])
                    )

                rec = {
                    "stakeholders": ["ops", "compliance", "data"],
                    "jobs": ["intake", "er", "report"],
                    "metrics": [
                        {"name": "ttr", "baseline": 40, "target": 25},
                        {"name": "precision_review", "baseline": 0.8, "target": 0.9},
                    ],

def extract_tail(path: Path) -> str:
    text = path.read_text(encoding="utf-8")
    m = re.search(r"\n  weDo: \{", text)
    if not m:
        raise RuntimeError(f"no weDo in {path}")
    return text[m.start() + 1 :]


def patch_weDo_intro(tail: str, intro: str) -> str:
    return re.sub(
        r'(weDo: \{\s*intro:\s*)"(?:[^"\\]|\\.)*"',
        lambda m: m.group(1) + q(intro),
        tail,
        count=1,
    )


def strip_from_youDo(tail: str) -> str:
    m = re.search(r"\n  youDo: \{", tail)
    if not m:
        raise RuntimeError("no youDo")
    return tail[: m.start()]


def emit_youDo(meta: dict) -> str:
    case = meta["case"]
    if meta["export"] == "section51":
        reqs = [
            "Incluye traces de prompt/retrieval/tool con redacción.",
            "Incluye registry y change log de versiones.",
            "Incluye SLO/drift/feedback/incidente/postmortem.",
            "Incluye UX accesible con incertidumbre, citas, confirmación y contestabilidad.",
            "Automatiza un caso normal, uno de breach (`ROLLBACK_COPILOT`) y uno incierto (`ESCALATE_TO_OWNER`).",
        ]
        keys = [
            "traces_de_prompt_retrieval_tool_con_redaccion",
            "registry_y_change_log_de_versiones",
            "slo_drift_feedback_incidente_postmortem",
            "ux_accesible_con_incertidumbre_citas_confirmacion_y_contestabili",
        ]
        portfolio = (
            "Evidencia de CP-N4-C + CF-5 · copiloto observable y contestable: muestra baseline, decisión, "
            "pruebas, resultado medido, rollback y riesgo residual. El checklist inicia en BLOCKED por diseño; "
            "conviértelo en READY enlazando artefactos reales del proyecto, no cambiando asserts."
        )
    else:
        reqs = [
            "Revalida CF-1 y declara no-go (sin real_pii ni auto_fraud_label).",
            "Integra bounded contexts con contract tests y HITL en decisiones sensibles.",
            "Ejecuta matriz de verificación sin P0/P1 y disaster exercise con RPO/RTO.",
            "Publica demo reproducible con métricas before/after sintéticas y evidencia bundle.",
            "Automatiza un caso normal, uno de breach (`NO_GO_RESILIENCE`) y uno incierto (`PREPARE_TECHNICAL_DEFENSE`).",
        ]
        keys = [
            "cf1_revalidado_y_nogo_firmado",
            "contexts_integrados_con_contract_tests_y_hitl",
            "verificacion_sin_p0_p1_y_disaster_exercise",
            "demo_before_after_y_evidence_bundle",
        ]
        portfolio = (
            "Evidencia de CP-FINAL · plataforma integral defendible: 12/12 capstones localizables, regresión "
            "total, demo reproducible y defensa de trade-offs. No compenses CP-N4-C con el portafolio final. "
            "Checklist inicia en BLOCKED; READY solo con artefactos reales."
        )
    req_lines = ",\n".join(q(r) for r in [
        f"Usa exclusivamente fixtures sintéticos identificados por `{case}`.",
        *reqs,
        "Incluye comandos locales reproducibles, dependencias fijadas y salida esperada.",
        "Registra riesgo residual, responsable, criterio de rollback y limitaciones conocidas.",
    ])
    keys_lit = "[" + ", ".join(q(k) for k in keys) + "]"
    evidence_lines = ",\n    ".join(f"{q(k)}: False" for k in keys)
    return f"""  youDo: {{
    title: {q(meta["title"])},
    context: {q(
        f'{meta["product"]}. Trabaja sobre {meta["org"]}. Caso {case} sintético: sin PII real ni secretos. '
        f'Gate: {meta["gate"]}.'
    )},
    objectives: [
      {q(f'Convertir entradas del caso en evidencia del gate {meta["gate"]}.')},
      {q("Demostrar el gate con artefactos reproducibles y fail-closed.")},
      {q("Probar el fallo: breach e incertidumbre no se convierten en éxito silencioso.")},
      {q("Entregar evidencia reproducible, redactada, sin PII real, secretos ni servicios externos obligatorios.")},
    ],
    requirements: [
      {req_lines}
    ],
    starterCode: `CASE_ID = {q(case)[1:-1]}
REQUIRED = {keys_lit}
evidence = {{
    {evidence_lines}
}}

def readiness(bundle: dict[str, bool]) -> tuple[str, list[str]]:
    missing = [name for name in REQUIRED if bundle.get(name) is not True]
    return ("READY", []) if not missing else ("BLOCKED", missing)

status, missing = readiness(evidence)
print(CASE_ID, status)
print("missing", ",".join(missing))
assert status in {{"READY", "BLOCKED"}}
`,
    portfolioNote: {q(portfolio)},
    rubric: [
      {{ criterion: "Correctitud del contrato y gate", weight: "25%" }},
      {{ criterion: "Pruebas normal/breach/uncertain y recuperación", weight: "20%" }},
      {{ criterion: "Seguridad, privacidad y least privilege", weight: "15%" }},
      {{ criterion: "Reproducibilidad, lineage y evidencia", weight: "15%" }},
      {{ criterion: "Operación: SLO, observabilidad y rollback", weight: "15%" }},
      {{ criterion: "Comunicación de trade-offs y límites", weight: "10%" }},
    ],
  }}"""


def emit_selfCheck(n: int, meta: dict, topics: list) -> str:
    case = meta["case"]
    if n == 51:
        qs = [
            (
                f"¿Qué evidencia permite aprobar traces de prompts/retrieval/tools en {case}?",
                [
                    "un print sin assert ni versión",
                    "una captura de pantalla sin fuente",
                    "trace reconstruible sin PII",
                    "datos personales reales para que parezca auténtico",
                ],
                2,
                "La teoría exige trace reconstruible sin PII; evidencia decorativa o PII no satisface el contrato.",
            ),
            (
                "Si el p95 supera el SLO o los tokens no cuadran, ¿qué respuesta es correcta?",
                [
                    "emitir ALERT_COST_LATENCY y conservar evidencia",
                    "promediar la latencia para bajar el p95",
                    "inventar redacted_fields=1",
                    "borrar el dashboard de costo",
                ],
                0,
                "El contrato falla cerrado con ALERT_COST_LATENCY; no maquilla métricas.",
            ),
            (
                "¿Cuál resultado demuestra el gate CP-N4-C + CF-5?",
                [
                    "el archivo S51 existe, aunque no pruebe el gate",
                    "se puede reconstruir qué respondió, qué citó, qué tool llamó, quién aprobó y cómo revertir",
                    "el README afirma que funciona",
                    "se usó la herramienta más nueva",
                ],
                1,
                "El gate es conductual y medible: reconstrucción completa + rollback.",
            ),
            (
                f"¿Qué tratamiento de {case} respeta el alcance del curso?",
                [
                    "reemplazarlo por datos reales sin consentimiento",
                    "subir secretos para facilitar la demo",
                    "inferir fraude o parentesco desde ER",
                    "mantenerlo sintético, mínimo, trazable y sujeto a revisión humana",
                ],
                3,
                "Los casos son sintéticos; señales no prueban fraude, parentesco ni riesgo.",
            ),
            (
                "Una acción con side-effect en el copiloto, ¿cuándo puede ejecutarse?",
                [
                    "siempre que el modelo esté confiado",
                    "solo tras confirmación explícita con citas e incertidumbre visibles",
                    "si el usuario no responde en 2 segundos",
                    "si el trace se borró para reducir ruido",
                ],
                1,
                "UX contestable: incertidumbre, citas y confirmación antes del efecto.",
            ),
        ]
    else:
        qs = [
            (
                "¿Qué demuestra que S52 es un checkpoint de integración y no un curso introductorio?",
                [
                    "vuelve a enseñar for-loops y listas desde cero",
                    "revalida CF-1…CF-5 e integra 12 capstones con contratos congelados",
                    "reemplaza todos los capstones por un único notebook",
                    "compensa CP-N4-C con un video de marketing",
                ],
                1,
                "S52 integra el path completo; no re-enseña reverse deps ni compensa CP-N4-C.",
            ),
            (
                "¿Cuáles no-go son obligatorios en el portafolio final?",
                [
                    "real_pii y auto_fraud_label",
                    "usar stdlib",
                    "escribir README",
                    "mostrar un diagrama C4",
                ],
                0,
                "PII real y auto-etiquetado de fraude están prohibidos; ER no prueba culpa.",
            ),
            (
                "Si hay un P1 abierto en la matriz de verificación, ¿qué corresponde?",
                [
                    "graduarse igual si el demo se ve bien",
                    "BLOCK_OPEN_SEVERITY hasta cerrar la severidad",
                    "ocultar el hallazgo en el video",
                    "mover el P1 a 'nice to have'",
                ],
                1,
                "Cero P0/P1 es gate de CP-FINAL y regresión total.",
            ),
            (
                "La demo de CV debe incluir:",
                [
                    "solo un logo y un eslogan",
                    "métricas before/after sintéticas, contribución personal y ejecución reproducible",
                    "datos personales de clientes reales",
                    "una afirmación de ROI sin benchmark",
                ],
                1,
                "Wow factor = ejecutable + medible + límites documentados.",
            ),
            (
                f"¿Qué tratamiento de {case} es correcto?",
                [
                    "mezclar PII real de varias regiones del Perú",
                    "auto-etiquetar fraude con el score de relationship",
                    "mantenerlo sintético multi-región, con HITL y regresión total",
                    "saltar CF-5 porque el video es convincente",
                ],
                2,
                "Caso sintético + HITL + CF-1…CF-5 y regresión; sin atajos de privacidad.",
            ),
        ]
    blocks = []
    for question, options, idx, expl in qs:
        opts = ", ".join(q(o) for o in options)
        blocks.append(
            f"""      {{
        question: {q(question)},
        options: [{opts}],
        correctIndex: {idx},
        explanation: {q(expl)},
      }}"""
        )
    return "  selfCheck: {\n    questions: [\n" + ",\n".join(blocks) + "\n    ],\n  }"


def emit_resources(n: int) -> str:
    r = RESOURCES[n]
    docs = ",\n".join(
        f"      {{\n        label: {q(lab)},\n        url: {q(url)},\n        note: {q(note)},\n      }}"
        for lab, url, note in r["docs"]
    )
    books = ",\n".join(f"      {{ label: {q(lab)}, note: {q(note)} }}" for lab, note in r["books"])
    courses = ",\n".join(
        f"      {{ label: {q(lab)}, url: {q(url)}, note: {q(note)} }}" for lab, url, note in r["courses"]
    )
    return f"""  resources: {{
    docs: [
{docs}
    ],
    books: [
{books}
    ],
    courses: [
{courses}
    ],
  }},
}}"""


def emit_section(n: int) -> tuple[str, list]:
    meta = SECTIONS_META[n]
    topics = BUILDERS[n]()
    theory_parts = []
    for t in topics:
        theory_parts.append(
            theory_block(
                t["heading"],
                t["sid"],
                t["paras"],
                t["title"],
                t["code"],
                t["callout_type"],
                t["callout_title"],
                t["callout"],
            )
        )
    demos = []
    for t in topics:
        if t["demo"]:
            d = t["demo"]
            demos.append(
                demo_step(
                    d["demoId"],
                    d["subtopicId"],
                    d["description"],
                    d["title"],
                    d["code"],
                    d["why"],
                )
            )

    path = SECTIONS / meta["file"]
    tail = extract_tail(path)
    tail = patch_weDo_intro(tail, meta["weDo_intro"])
    weDo_only = strip_from_youDo(tail).rstrip().rstrip(",") + ",\n"

    outcomes = ",\n".join(f"    {{ text: {q(o)} }}" for o in meta["outcomes"])
    theory_joined = ",\n".join(theory_parts)
    demos_joined = ",\n".join(demos)
    ido_intro = q(f'Te muestro 8 demos de S{n:02d} ({meta["title"]}) alineadas a {meta["gate"]}.')

    head = f"""import type {{ CourseSection }} from '../../types'

export const {meta["export"]}: CourseSection = {{
  id: {q(meta["id"])},
  index: {n},
  title: {q(meta["title"])},
  shortTitle: {q(meta["shortTitle"])},
  tagline: {q(meta["tagline"])},
  estimatedHours: {meta["hours"]},
  level: "Master",
  phase: 3,
  icon: {q(meta["icon"])},
  accentColor: "bg-gradient-to-br from-amber-500 to-red-600",
  jobRelevance:
    {q(meta["job"])},
  learningOutcomes: [
{outcomes}
  ],
  theory: [
{theory_joined}
  ],
  iDo: {{
    intro: {ido_intro},
    steps: [
{demos_joined}
    ],
  }},
"""
    body = (
        head
        + weDo_only
        + emit_youDo(meta)
        + ",\n"
        + emit_selfCheck(n, meta, topics)
        + ",\n"
        + emit_resources(n)
        + "\n"
    )
    return body, topics



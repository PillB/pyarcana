            ("Python queue — stdlib", "https://docs.python.org/3/library/queue.html", "Colas locales didácticas"),
            ("Py4E", "https://www.py4e.com", "Progressive disclosure"),
        ],
        "books": [
            ("Designing Data-Intensive Applications", "Consistencia, colas, almacenamiento"),
            ("Site Reliability Engineering", "SLO, capacidad, incidentes"),
            ("Terraform Up & Running", "IaC multi-env y state"),
        ],
        "courses": [
            ("MIT OCW 6.100L", "https://ocw.mit.edu/courses/6-100l-introduction-to-cs-and-programming-using-python-fall-2022/", "Contratos verificables"),
            ("Harvard CS50P", "https://cs50.harvard.edu/python/", "Problem sets y tests"),
            ("Coursera — Cloud architecture patterns (ref)", "https://www.coursera.org", "Patrones cloud de alto nivel"),
            ("deeplearning.ai Data Engineering", "https://www.deeplearning.ai/specializations/data-engineering", "Pipelines y cloud data"),
        ],
    },
    46: {
        "docs": [
            ("Apache Beam programming guide", "https://beam.apache.org/documentation/programming-guide/", "Event time, windows, watermarks"),

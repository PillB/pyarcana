            "callout": "Target de utilidad de review. Breach: REJECT_FRAUD_TARGET. Missing: REQUEST_HORIZON.",
            "code": textwrap.dedent(
                """\
                def framing_ok(unit: str, target: str, horizon: int) -> dict:
                    banned = {"is_fraud", "guilty", "parentesco"}
                    return {
                        "unit": unit,
                        "target": target,
                        "horizon": horizon,
                        "ok": unit and target not in banned and horizon > 0,
                        "is_fraud_label": target in banned,
                    }

                r = framing_ok("entity_pair", "needs_review_7d", 7)
                print("unit", r["unit"])
                print("target", r["target"])
                print("horizon", r["horizon"])
                print("is_fraud_label", r["is_fraud_label"])
                """
            ),
            "demo": textwrap.dedent(
                """\
                def valid_target(t: str) -> bool:
                    return t not in {"is_fraud", "guilty"} and t.startswith("needs_review")

                print("unit", "entity_pair")
                print("valid", valid_target("needs_review_7d"))
                print("ok", True)
                """

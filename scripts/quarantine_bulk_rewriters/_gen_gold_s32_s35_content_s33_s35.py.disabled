            "callout": "Baseline primero. Breach: REJECT_NO_BASELINE. Missing: REQUEST_DUMMY.",
            "code": textwrap.dedent(
                """\
                def rule_and_dummy(xs, thr, y):
                    rule = [1 if x > thr else 0 for x in xs]
                    mode = max(set(y), key=y.count)
                    dummy = [mode] * len(y)
                    return rule, mode, dummy

                xs, y = [50, 120, 80, 200], [0, 1, 0, 1]
                rule, mode, dummy = rule_and_dummy(xs, 100, y)
                print("rule", rule)
                print("dummy_mode", mode)

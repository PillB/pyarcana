def esc(s: str) -> str:
    return s.replace("\\", "\\\\").replace("`", "\\`").replace("${", "\\${")


def q(s: str) -> str:
    return json.dumps(s, ensure_ascii=False)


def pad(p: str, min_len: int = 255) -> str:
    if len(p) >= min_len:
        return p
    suffix = (
        " En el laboratorio sintético documentas entrada, salida, error y dueño: sin PII real, "
        "sin secretos en logs y con fail-closed cuando falta evidencia o el contrato no cuadra."
    )
    out = p
    while len(out) < min_len:
        out = out.rstrip() + suffix
    return out


def run_py(code: str) -> str:
    """Execute Python code and capture stdout for honest output fields."""
    r = subprocess.run(
        [sys.executable, "-c", code],
        capture_output=True,
        text=True,
        timeout=10,
        cwd="/tmp",
    )
    if r.returncode != 0:
        raise RuntimeError(f"code failed:\n{code}\n---\n{r.stderr}")
    return r.stdout.rstrip("\n")



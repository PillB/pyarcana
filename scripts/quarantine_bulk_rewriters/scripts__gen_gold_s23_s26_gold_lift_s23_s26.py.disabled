# ---------------------------------------------------------------------------
# Emit weDo step TS
# ---------------------------------------------------------------------------

def emit_step(p: dict, case: str) -> str:
    starter = header(case, p["defect"]) + textwrap.dedent(p["starter"]).lstrip("\n")
    solution = textwrap.dedent(p["solution"]).strip() + "\n"
    # Verify solution
    out = run_py(solution)
    if out != p["output"]:
        # allow if pack output wrong - use actual
        # but prefer pack for grader stability
        if p["output"] != out:
            raise AssertionError(f"{p['id']}: expected {p['output']!r} got {out!r}")
    # Verify starter differs (best effort)
    try:
        st_out = run_py(textwrap.dedent(p["starter"]).strip())
        if st_out == out:
            print(f"  WARN {p['id']}: starter output matches solution ({out!r})")
    except Exception:
        pass  # starter may raise — ok for some designs

    fname = p["id"].lower() + ".py"
    instr = p["instruction"]
    if len(instr) < 150:
        instr += f" Usa fixture sintético {case}; imprime exactamente el pass string; sin PII real."
    hint = f"Repara el DEFECT: {p['defect']}."
    return f"""      {{
        id: "{p['id']}",
        subtopicId: "{p['sub']}",
        kind: "{p['kind']}",
        instruction: {json.dumps(instr, ensure_ascii=False)},
        hint: {json.dumps(hint, ensure_ascii=False)},
        hints: [
          {json.dumps(hint, ensure_ascii=False)},
          "Conserva fixtures y el contrato de prints; no borres def.",
          "Datos sintéticos only · fail-closed / HITL cuando aplique.",
        ],
        edgeCases: ["fixture sintético", "defect de dominio", {json.dumps(case, ensure_ascii=False)}],
        tests: {json.dumps(f"Salida alinea con solution output de {p['id']}; fixture {case}.", ensure_ascii=False)},
        feedback: {json.dumps(f"{p['id']}: {p['defect']} corregido; contrato reproducible.", ensure_ascii=False)},
        starterCode: {{
          language: 'python',
          title: "{fname}",
          code: `{esc_ts(starter)}`,
        }},
        solutionCode: {{
          language: 'python',
          title: "{fname}",
          code: `{esc_ts(solution)}`,
          output: `{esc_ts(out)}`,
        }},
      }}"""


def pad_theory_in_file(text: str) -> str:
    """Pad double-quoted theory paragraphs to ≥255 chars."""

    def repl_paragraphs(m: re.Match) -> str:
        body = m.group(1)
        strings = re.findall(r'"((?:[^"\\]|\\.)*)"', body)
        if not strings:
            return m.group(0)
        new_parts = []
        # rebuild body with padded strings
        def pad_one(sm: re.Match) -> str:
            raw = sm.group(1)
            # unescape lightly for length check
            unesc = (
                raw.replace("\\n", "\n")
                .replace('\\"', '"')
                .replace("\\\\", "\\")
            )
            padded = pad_para(unesc, 255)
            return json.dumps(padded, ensure_ascii=False)

        new_body = re.sub(r'"((?:[^"\\]|\\.)*)"', pad_one, body)
        return "paragraphs: [" + new_body + "]"

    # only theory section
    tm = re.search(r"(theory:\s*\[)([\s\S]*?)(\n  \],\n  iDo:)", text)
    if not tm:
        return text
    theory = tm.group(2)
    theory2 = re.sub(
        r"paragraphs:\s*\[([\s\S]*?)\]",
        lambda m: "paragraphs: ["
        + re.sub(
            r'"((?:[^"\\]|\\.)*)"',
            lambda sm: json.dumps(
                pad_para(
                    sm.group(1)
                    .replace("\\n", "\n")
                    .replace('\\"', '"')
                    .replace("\\\\", "\\"),
                    255,
                ),
                ensure_ascii=False,
            ),
            m.group(1),
        )
        + "]",
        theory,
    )
    return text[: tm.start(2)] + theory2 + text[tm.end(2) :]


def ensure_selfcheck(text: str, section: int) -> str:
    """Ensure ≥5 selfCheck questions."""
    sc = re.search(r"selfCheck:\s*\{\s*questions:\s*\[([\s\S]*?)\]\s*,?\s*\}", text)
    if not sc:
        return text
    body = sc.group(1)
    n = len(re.findall(r"correctIndex:", body))
    extras = {
        23: [
            {
                "q": "¿Qué evidencia mínima adjunta un robot al fallar un paso crítico?",
                "opts": [
                    "Solo el stack trace del lenguaje",
                    "Trace, screenshot y error accionable del paso",
                    "El password del usuario en claro",
                    "Un sleep de 30 segundos",
                ],
                "i": 1,
                "e": "Trace + screenshot + error del step hacen el fallo accionable sin secretos.",
            },
            {
                "q": "¿Cuándo es aceptable un Page Object en el adaptador web?",
                "opts": [
                    "Para esconder ToS violations",
                    "Para centralizar selectores y flujos de auth reutilizables",
                    "Para bypassear CAPTCHA",
                    "Solo en cloud",
                ],
                "i": 1,
                "e": "Page Objects encapsulan selectores/auth; no legitiman bypass ético.",
            },
        ],
        24: [
            {
                "q": "¿Por qué conservar bounding boxes en el intake?",
                "opts": [
                    "Para auto-etiquetar fraude",
                    "Como evidencia de dónde se leyó el campo para revisión humana",
                    "Para comprimir el PDF",
                    "Solo estética",
                ],
                "i": 1,
                "e": "bbox es evidencia de extracción, no prueba de conducta indebida.",
            },
            {
                "q": "Si confidence de RUC < umbral, el sistema debe:",
                "opts": [
                    "Inventar el dígito faltante",
                    "Abstenerse y encolar revisión humana",
                    "Marcar fraude automáticamente",
                    "Borrar el documento",
                ],
                "i": 1,
                "e": "Abstención bajo confidence es control de calidad fail-closed.",
            },
        ],
        25: [
            {
                "q": "¿Qué hace válida una salida de LLM en este curso?",
                "opts": [
                    "Que suene convincente",
                    "JSON con schema + evidencia + eval vs baseline; humano si falla",
                    "Que el score sea >0.9 de fraude",
                    "Que use el modelo más grande",
                ],
                "i": 1,
                "e": "Schema, evidencia y eval; nunca auto-fraude.",
            },
            {
                "q": "Ante prompt injection ('ignore previous instructions') el adapter debe:",
                "opts": [
                    "Obedecer la instrucción inyectada",
                    "Señalar riesgo, minimizar datos y/o human_review",
                    "Enviar PII al proveedor público",
                    "Desactivar logs",
                ],
                "i": 1,
                "e": "Injection → señal + minimización + HITL, no obediencia.",
            },
        ],
        26: [
            {
                "q": "¿Qué garantiza el checkpoint en el VP orquestado?",
                "opts": [
                    "Que el correo se envíe sin aprobación",
                    "Reanudación sin rehacer trabajo durable ya confirmado",
                    "Que el DAG tenga ciclos",
                    "PII real en logs",
                ],
                "i": 1,
                "e": "Checkpoint permite resume idempotente sin duplicar efectos.",
            },
            {
                "q": "CF-2 en S26 fija principalmente:",
                "opts": [
                    "El color del dashboard",
                    "Interfaces Familiarity↔reporting↔RPA/IA y flujo de aprobación",
                    "El modelo de LLM obligatorio en cloud",
                    "Bypass de ToS",
                ],
                "i": 1,
                "e": "CF-2 = contratos de interfaz y aprobación, con regresión N2.",
            },
        ],
    }
    if n >= 5:
        return text
    add = extras.get(section, extras[23])
    need = 5 - n
    chunks = []
    for item in add[: max(need, 0) + 1]:
        chunks.append(
            f"""      {{
        question: {json.dumps(item['q'], ensure_ascii=False)},
        options: {json.dumps(item['opts'], ensure_ascii=False)},
        correctIndex: {item['i']},
        explanation:
          {json.dumps(item['e'], ensure_ascii=False)},
      }}"""
        )
    insert = ",\n".join(chunks)
    new_body = body.rstrip().rstrip(",") + ",\n" + insert + "\n    "
    return text[: sc.start(1)] + new_body + text[sc.end(1) :]



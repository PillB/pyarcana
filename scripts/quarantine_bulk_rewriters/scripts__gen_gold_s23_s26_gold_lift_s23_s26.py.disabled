def esc_ts(s: str) -> str:
    return s.replace("\\", "\\\\").replace("`", "\\`").replace("${", "\\${")


def run_py(code: str) -> str:
    r = subprocess.run(["python3", "-c", code], capture_output=True, text=True, timeout=8)
    if r.returncode != 0:
        raise RuntimeError(f"code failed:\n{code}\n---\n{r.stderr}")
    return r.stdout.rstrip("\n")


def pad_para(p: str, min_len: int = 255) -> str:
    if len(p) >= min_len:
        return p
    suffix = (
        " En el laboratorio sintético documentas contrato de entrada/salida, evidencia "
        "reproducible y límites: sin PII real, sin secretos, sin auto-etiqueta de fraude "
        "ni parentesco, y con fail-closed o handoff humano cuando falte dueño, schema o prueba."
    )
    out = p.rstrip()
    while len(out) < min_len:
        out = out + suffix
    return out


def header(case: str, defect: str) -> str:
    return (
        f"# {case} sintético · lab PE · sin PII real\n"
        f"# Repara solo el DEFECT; conserva fixtures y el contrato de prints.\n"
        f"# DEFECT: {defect}\n"
    )



leaky = [n for n in names if "label" in n or "decision" in n]
train_mean, serve_mean = 0.0, 0.8
print("leaky", leaky)
print("skew", abs(serve_mean - train_mean) > 0.5)
print("feature_set", "fs-v2")""",
            output="""leaky ['label_decision']
skew True
feature_set fs-v2""",

# Dynamic LMS only. GitHub Pages does not use server environment variables.
DATABASE_URL="file:./db/custom.db"

# Required for every dynamic deployment. Generate a unique value with:
# openssl rand -base64 32
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Optional server-side profile mirroring. Leave unset to disable it.
FIREBASE_PROJECT_ID=""
FIREBASE_CLIENT_EMAIL=""
FIREBASE_PRIVATE_KEY=""
